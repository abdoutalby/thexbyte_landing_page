---
export interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  noindex?: boolean;
  structuredData?: object;
}

const {
  title = "TheXbyte - Digital Solutions & Innovation",
  description = "Transform your business with cutting-edge digital solutions, mobile applications, and automation systems. Custom software development, mobile apps, and automation solutions.",
  canonicalUrl,
  noindex = false,
  structuredData
} = Astro.props;

// Default structured data
const defaultStructuredData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "TheXbyte",
  "url": "https://abdoutalby.github.io/thexbyte_landing_page",
  "logo": "https://abdoutalby.github.io/thexbyte_landing_page/logo.png",
  "description": "Digital solutions and innovation company providing custom software development, mobile applications, and automation systems.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "avenue 18 janvier ariana centre escalier c bureau c 408",
    "addressLocality": "Ariana",
    "addressCountry": "Tunisia"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+216-21-238-537",
    "contactType": "customer service",
    "email": "hello@thexbyte.com"
  },
  "sameAs": [
    "https://www.linkedin.com/company/thexbyte",
    "https://twitter.com/thexbyte",
    "https://github.com/thexbyte"
  ]
};

const pageStructuredData = structuredData || defaultStructuredData;
const pageUrl = canonicalUrl || "https://abdoutalby.github.io/thexbyte_landing_page";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Basic Meta Tags -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="keywords" content="digital solutions, custom software development, mobile applications, automation systems, web development, Tunisia, TheXbyte" />
    <meta name="author" content="TheXbyte" />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    
    <!-- Open Graph Meta Tags (for social media) -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="TheXbyte" />
    <meta property="og:locale" content="en_US" />
    <meta name="msvalidate.01" content="6FA0E4E0F5C04950B0FF8D4502761B3F" />
    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:site" content="@thexbyte" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={pageUrl} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    
    <!-- Structured Data -->
    <script type="application/ld+json">
      {JSON.stringify(pageStructuredData)}
    </script>
    
    <!-- Additional Schema Markup for Local Business -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "TheXbyte",
        "image": "https://abdoutalby.github.io/thexbyte_landing_page/logo.png",
        "description": "Digital solutions and innovation company in Tunisia",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "avenue 18 janvier ariana centre escalier c bureau c 408",
          "addressLocality": "Ariana",
          "addressCountry": "Tunisia"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "36.8665",
          "longitude": "10.1647"
        },
        "url": "https://abdoutalby.github.io/thexbyte_landing_page",
        "telephone": "+216-21-238-537",
        "openingHours": "Mo-Fr 09:00-18:00, Sa 10:00-16:00",
        "priceRange": "$$",
        "areaServed": "Tunisia, Worldwide"
      }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js"></script>
    <link rel="stylesheet" href="/global.css" />
  </head>
  <body>
    <slot />
    
    <script>
      // Enhanced JavaScript for GitHub Pages compatibility
      document.addEventListener('DOMContentLoaded', function() {
        // Smooth scroll for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
          anchor.addEventListener('click', function (e) {
            const href = this.getAttribute('href');
            if (href !== '#' && href !== '') {
              e.preventDefault();
              const target = document.querySelector(href);
              if (target) {
                target.scrollIntoView({ behavior: 'smooth' });
                
                // Update URL without page reload (for SPA behavior)
                history.pushState(null, null, href);
              }
            }
          });
        });

        // Mobile Menu Toggle
        const menuToggle = document.getElementById('menuToggle');
        const navLinks = document.getElementById('navLinks');

        if (menuToggle && navLinks) {
          menuToggle.addEventListener('click', () => {
            navLinks.classList.toggle('active');
          });

          // Close menu when a link is clicked
          navLinks.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
              navLinks.classList.remove('active');
            });
          });
        }

        // Modal functionality
        const consultationModal = document.getElementById('consultationModal');
        const quoteModal = document.getElementById('quoteModal');
        const modalClose = document.getElementById('modalClose');
        const quoteModalClose = document.getElementById('quoteModalClose');
        const getStartedBtn = document.getElementById('getStartedBtn');
        const heroCtaBtn = document.getElementById('heroCtaBtn');
        const ctaConsultationBtn = document.getElementById('ctaConsultationBtn');

        // Modal open/close functions
        function openModal(modal) {
          if (modal) {
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
          }
        }

        function closeModal(modal) {
          if (modal) {
            modal.style.display = 'none';
            document.body.style.overflow = 'auto';
          }
        }

        // Open consultation modal
        [getStartedBtn, heroCtaBtn, ctaConsultationBtn].forEach(btn => {
          if (btn) {
            btn.addEventListener('click', () => openModal(consultationModal));
          }
        });

        // Close modals
        if (modalClose) {
          modalClose.addEventListener('click', () => closeModal(consultationModal));
        }
        if (quoteModalClose) {
          quoteModalClose.addEventListener('click', () => closeModal(quoteModal));
        }

        // Close modal when clicking outside
        [consultationModal, quoteModal].forEach(modal => {
          if (modal) {
            modal.addEventListener('click', (e) => {
              if (e.target === modal) {
                closeModal(modal);
              }
            });
          }
        });

        // Service card click handlers
        document.querySelectorAll('.service-card').forEach(card => {
          card.addEventListener('click', (e) => {
            e.preventDefault();
            openModal(quoteModal);
            
            // Pre-select the service in the quote form
            const service = card.getAttribute('data-service');
            const quoteServiceSelect = document.getElementById('quoteService');
            if (quoteServiceSelect) {
              quoteServiceSelect.value = service;
            }
          });
        });

        // Learn More button scroll to services
        const learnMoreBtn = document.getElementById('learnMoreBtn');
        if (learnMoreBtn) {
          learnMoreBtn.addEventListener('click', () => {
            const servicesSection = document.getElementById('services');
            if (servicesSection) {
              servicesSection.scrollIntoView({ behavior: 'smooth' });
            }
          });
        }

        // Service options selection for consultation form
        const serviceOptions = document.querySelectorAll('.service-option');
        const consultServicesInput = document.getElementById('consultServices');
        let selectedServices = [];

        serviceOptions.forEach(option => {
          option.addEventListener('click', () => {
            option.classList.toggle('selected');
            const value = option.getAttribute('data-value');
            
            if (selectedServices.includes(value)) {
              selectedServices = selectedServices.filter(s => s !== value);
            } else {
              selectedServices.push(value);
            }
            
            if (consultServicesInput) {
              consultServicesInput.value = selectedServices.join(', ');
            }
          });
        });

        // Set minimum date to today for consultation form
        const consultDateInput = document.getElementById('consultDate');
        if (consultDateInput) {
          const today = new Date().toISOString().split('T')[0];
          consultDateInput.setAttribute('min', today);
        }

        // ─── EmailJS configuration ───────────────────────────────────────────
        // Replace the three values below with your real EmailJS credentials.
        // Service ID  : found in EmailJS dashboard → Email Services
        // Template IDs: found in EmailJS dashboard → Email Templates
        // Public Key  : found in EmailJS dashboard → Account → API Keys
        const EMAILJS_SERVICE_ID   = 'service_thexbyte';
        const EMAILJS_CONTACT_TPL  = 'template_contact';
        const EMAILJS_CONSULT_TPL  = 'template_consultation';
        const EMAILJS_QUOTE_TPL    = 'template_quote';
        const EMAILJS_NEWSLETTER_TPL = 'template_newsletter';
        const EMAILJS_PUBLIC_KEY   = 'YOUR_PUBLIC_KEY';

        if (typeof emailjs !== 'undefined') {
          emailjs.init(EMAILJS_PUBLIC_KEY);
        }

        // ─── Helper: show status message ─────────────────────────────────────
        function showStatus(statusEl, message, type) {
          statusEl.textContent = message;
          statusEl.className = 'form-status ' + type;
          statusEl.style.display = 'block';
        }

        // ─── Helper: set button loading state ────────────────────────────────
        function setLoading(btn, spinner, loading) {
          btn.disabled = loading;
          btn.textContent = loading ? 'Sending…' : (btn.getAttribute('data-original-text') || 'Submit');
          if (spinner) spinner.style.display = loading ? 'block' : 'none';
        }

        // ─── Helper: send via EmailJS or fallback ────────────────────────────
        function sendForm(form, templateId) {
          if (typeof emailjs !== 'undefined' && EMAILJS_PUBLIC_KEY !== 'YOUR_PUBLIC_KEY') {
            return emailjs.sendForm(EMAILJS_SERVICE_ID, templateId, form);
          }
          // Fallback: simulate success for local dev / missing credentials
          return new Promise(resolve => setTimeout(resolve, 900));
        }

        // ─── Store original button text BEFORE attaching listeners ───────────
        document.querySelectorAll('form button[type="submit"]').forEach(btn => {
          btn.setAttribute('data-original-text', btn.textContent.trim());
        });

        // ─── Contact Form ─────────────────────────────────────────────────────
        const contactForm = document.getElementById('contactForm');
        if (contactForm) {
          contactForm.addEventListener('submit', function(e) {
            e.preventDefault();
            const btn      = this.querySelector('button[type="submit"]');
            const statusEl = document.getElementById('contactStatus');
            const spinner  = null; // contact form has no spinner element
            statusEl.style.display = 'none';
            setLoading(btn, spinner, true);

            sendForm(this, EMAILJS_CONTACT_TPL)
              .then(() => {
                showStatus(statusEl, '✅ Message sent! We\'ll get back to you within 24 hours.', 'success');
                this.reset();
              })
              .catch(() => {
                showStatus(statusEl, '❌ Something went wrong. Please email us directly at hello@thexbyte.com', 'error');
              })
              .finally(() => {
                setLoading(btn, spinner, false);
              });
          });
        }

        // ─── Newsletter Form ──────────────────────────────────────────────────
        const newsletterForm = document.getElementById('newsletterForm');
        if (newsletterForm) {
          newsletterForm.addEventListener('submit', function(e) {
            e.preventDefault();
            const btn      = this.querySelector('button[type="submit"]');
            const statusEl = document.getElementById('newsletterStatus');
            statusEl.style.display = 'none';
            setLoading(btn, null, true);

            sendForm(this, EMAILJS_NEWSLETTER_TPL)
              .then(() => {
                showStatus(statusEl, '✅ You\'re subscribed! Thank you for joining our newsletter.', 'success');
                this.reset();
              })
              .catch(() => {
                showStatus(statusEl, '❌ Subscription failed. Please try again later.', 'error');
              })
              .finally(() => {
                setLoading(btn, null, false);
              });
          });
        }

        // ─── Consultation Form ────────────────────────────────────────────────
        const consultationForm = document.getElementById('consultationForm');
        if (consultationForm) {
          consultationForm.addEventListener('submit', function(e) {
            e.preventDefault();
            const btn       = this.querySelector('button[type="submit"]');
            const spinner   = document.getElementById('consultSpinner');
            const statusEl  = document.getElementById('consultStatus');
            const servicesInput = document.getElementById('consultServices');
            statusEl.style.display = 'none';

            // Validate that at least one service is selected
            if (!servicesInput || !servicesInput.value.trim()) {
              showStatus(statusEl, '⚠️ Please select at least one service.', 'error');
              return;
            }

            setLoading(btn, spinner, true);

            sendForm(this, EMAILJS_CONSULT_TPL)
              .then(() => {
                showStatus(statusEl, '✅ Consultation booked! We\'ll confirm your appointment by email shortly.', 'success');
                this.reset();
                // Reset service option visuals
                document.querySelectorAll('.service-option').forEach(opt => opt.classList.remove('selected'));
                selectedServices = [];
                if (servicesInput) servicesInput.value = '';
                setTimeout(() => closeModal(consultationModal), 3000);
              })
              .catch(() => {
                showStatus(statusEl, '❌ Booking failed. Please contact us directly at hello@thexbyte.com', 'error');
              })
              .finally(() => {
                setLoading(btn, spinner, false);
              });
          });
        }

        // ─── Quote Form ───────────────────────────────────────────────────────
        const quoteForm = document.getElementById('quoteForm');
        if (quoteForm) {
          quoteForm.addEventListener('submit', function(e) {
            e.preventDefault();
            const btn      = this.querySelector('button[type="submit"]');
            const spinner  = document.getElementById('quoteSpinner');
            const statusEl = document.getElementById('quoteStatus');
            statusEl.style.display = 'none';
            setLoading(btn, spinner, true);

            sendForm(this, EMAILJS_QUOTE_TPL)
              .then(() => {
                showStatus(statusEl, '✅ Quote request received! We\'ll send you an estimate within 48 hours.', 'success');
                this.reset();
                setTimeout(() => closeModal(quoteModal), 3000);
              })
              .catch(() => {
                showStatus(statusEl, '❌ Request failed. Please email us at hello@thexbyte.com', 'error');
              })
              .finally(() => {
                setLoading(btn, spinner, false);
              });
          });
        }

        // Intersection Observer for animations
        const observerOptions = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.style.opacity = '1';
              entry.target.style.transform = 'translateY(0)';
            }
          });
        }, observerOptions);

        // Observe elements for animation
        document.querySelectorAll('.service-card, .stat, .portfolio-item, .testimonial-card').forEach(el => {
          el.style.opacity = '0';
          el.style.transform = 'translateY(20px)';
          el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
          observer.observe(el);
        });
      });

      // Handle escape key for modals
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          const modals = document.querySelectorAll('.modal');
          modals.forEach(modal => {
            if (modal.style.display === 'flex') {
              modal.style.display = 'none';
              document.body.style.overflow = 'auto';
            }
          });
        }
      });
    </script>
  </body>
</html>
